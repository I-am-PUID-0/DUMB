{
  "name": "DUMB Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "options": [
      "--pull"
    ],
    "args": {
      "DUMB_IMAGE": "iampuid0/dumb:dev"
    }
  },
  "workspaceFolder": "/workspace",
  "remoteEnv": {
    "PATH": "/opt/poetry/bin:/venv/bin:${containerEnv:PATH}",
    "VIRTUAL_ENV": "/venv"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.formatting.provider": "black",
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/venv/bin/python",
        "git.path": "/usr/bin/git"
      }
    }
  },
  "forwardPorts": [
    3005,
    8000,
    3000,
    9090,
    5050,
    8182,
    8282,
    32400
  ],
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "source=${localWorkspaceFolder}/main.py,target=/main.py,type=bind",
    "source=${localWorkspaceFolder}/utils,target=/utils,type=bind",
    "source=${localWorkspaceFolder}/data,target=/data,type=bind",
    "source=${localWorkspaceFolder}/log,target=/log,type=bind",
    "source=${localWorkspaceFolder}/config,target=/config,type=bind",
    "source=${localWorkspaceFolder}/mnt/debrid,target=/mnt/debrid,type=bind,bind-propagation=rshared",
    "source=codex-home,target=/root/.codex,type=volume",
    "source=claude-home,target=/root/.claude,type=volume"
  ],
  "runArgs": [
    "--name=dumb_dev",
    "--hostname=dumb_dev",
    "--dns=8.8.8.8",
    "--dns=8.8.4.4",
    "--device=/dev/fuse:/dev/fuse:rwm",
    "--cap-add=SYS_ADMIN",
    "--security-opt=apparmor:unconfined",
    "--shm-size=128m"
  ],
  "postCreateCommand": "bash .devcontainer/setup-workspace.sh",
  "postAttachCommand": "bash .devcontainer/setup-workspace.sh"
}
